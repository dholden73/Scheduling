WITH material_requirement_sch AS (
  SELECT
    mr.datamart_sk,
    mr.material_use,
    mr.material_class_id,
    mr.material_definition_id,
    mr.material_lot_id,
    mr.storage_location,
    mr.storage_location_type,
    mr.schedule_id,
    mr.order_start_time,
    mr.order_end_time,
    mr.schedule_start_time,
    mr.schedule_end_time,
    mr.work_master_id,
    mr.mass,
    mr.total_prod_drill_meters,
    mr.progression_meters
  FROM datamart.material_requirement mr
  LEFT JOIN datamart.job_order jo
    ON mr.parent_entity_sk = jo.job_order_sk
  LEFT JOIN datamart.work_request wr
    ON jo.parent_entity_sk = wr.work_request_sk
  LEFT JOIN datamart.work_schedule ws
    ON wr.parent_entity_sk = ws.work_schedule_sk
  WHERE mr.schedule_id ILIKE 'W%'
    AND mr.material_use = 'Produced'
),
cross_calendar AS (
  SELECT
    cal.*,
    wm.wm AS work_master_id
  FROM datamart.cal_days cal
  CROSS JOIN (
    SELECT DISTINCT work_master_id AS wm
    FROM datamart.job_response
  ) wm
  WHERE cal.date >= date_trunc('year', CURRENT_DATE)
),
plan AS (
  SELECT
    c.date,
    p.schedule_id,
    p.material_definition_id,
    p.work_master_id,
    'Produced'::text AS material_use,
    MAX(qp.uom) AS planned_uom,
    SUM(
      COALESCE(qp.value_num, 0) *
      EXTRACT(
        EPOCH FROM (
          LEAST(p.order_end_time, c.period_end)
          - GREATEST(p.order_start_time, c.period_start)
        )
      ) /
      NULLIF(EXTRACT(EPOCH FROM (p.order_end_time - p.order_start_time)), 0)
    ) AS planned_quantity
  FROM cross_calendar c
  LEFT JOIN material_requirement_sch p
    ON p.work_master_id = c.work_master_id
   AND p.order_end_time > c.period_start
   AND p.order_start_time < c.period_end
  LEFT JOIN datamart.quantity qp
    ON qp.parent_datamart_sk = p.datamart_sk
   AND qp.key ILIKE 'mass'
  GROUP BY
    c.date,
    p.work_master_id,
    p.schedule_id,
    p.material_definition_id
),
actual AS (
  SELECT
    c.date,
    c.work_master_id,
    'Produced'::text AS material_use,
    MAX(qa.uom) AS actual_uom,
    SUM(COALESCE(qa.value_num, 0)) AS actual_quantity
  FROM cross_calendar c
  LEFT JOIN datamart.job_response jr
    ON jr.work_master_id = c.work_master_id
   AND jr.end_time > c.period_start
   AND jr.start_time < c.period_end
  LEFT JOIN datamart.material_actual ma
    ON ma.parent_datamart_sk = jr.datamart_sk
   AND ma.material_use = 'Produced'
  LEFT JOIN datamart.quantity qa
    ON qa.parent_datamart_sk = ma.datamart_sk
   AND qa.key ILIKE 'mass'
  GROUP BY
    c.date,
    c.work_master_id
),
joined AS (
  SELECT
    c.date AS production_day,
    MIN(c.period_start) AS period_start,
    MAX(c.period_end) AS period_end,
    c.work_master_id,
    'Produced'::text AS material_use,
    p.schedule_id,
    COALESCE(a.actual_quantity, 0) AS actual_quantity,
    COALESCE(p.planned_quantity, 0) AS planned_quantity,
    coalesce(a.actual_uom,p.planned_uom) as uom
  FROM cross_calendar c
  LEFT JOIN plan p
    ON p.date = c.date
   AND p.work_master_id = c.work_master_id
  LEFT JOIN actual a
    ON a.date = c.date
   AND a.work_master_id = c.work_master_id
  GROUP BY
    c.date,
    c.work_master_id,
    p.schedule_id,
    a.actual_quantity,
    p.planned_quantity,
    a.actual_uom,
    p.planned_uom
)
SELECT
  *,
  SUM(planned_quantity) OVER (
    PARTITION BY work_master_id, material_use, schedule_id
    ORDER BY production_day
    ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
  ) AS running_planned_quantity,
  SUM(actual_quantity) OVER (
    PARTITION BY work_master_id, material_use
    ORDER BY production_day
    ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
  ) AS running_actual_quantity,
  (actual_quantity - planned_quantity) AS variance,
  (
    SUM(actual_quantity) OVER (
      PARTITION BY work_master_id, material_use
      ORDER BY production_day
      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    ) -
    SUM(planned_quantity) OVER (
      PARTITION BY work_master_id, material_use, schedule_id
      ORDER BY production_day
      ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    )
  ) AS running_sum_variance,
  CASE
    WHEN (actual_quantity - planned_quantity) > 0 THEN 'Actual (Above planned)'
    WHEN (actual_quantity - planned_quantity) < 0 THEN 'Actual (Below planned)'
    ELSE 'Actual (On target)'
  END AS variance_color,
  CASE
    WHEN (
      SUM(actual_quantity) OVER (
        PARTITION BY work_master_id, material_use
        ORDER BY production_day
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
      ) -
      SUM(planned_quantity) OVER (
        PARTITION BY work_master_id, material_use
        ORDER BY production_day
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
      )
    ) > 0 THEN 'Actual (Above planned)'
    WHEN (
      SUM(actual_quantity) OVER (
        PARTITION BY work_master_id, material_use
        ORDER BY production_day
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
      ) -
      SUM(planned_quantity) OVER (
        PARTITION BY work_master_id, material_use
        ORDER BY production_day
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
      )
    ) < 0 THEN 'Actual (Below planned)'
    ELSE 'Actual (On target)'
  END AS running_variance_color
FROM joined
--where schedule_id = 'WK_2026_01_20251230_OMS_V1'
where work_master_id = 'Prod Extraction'
ORDER BY production_day, work_master_id, schedule_id DESC;
